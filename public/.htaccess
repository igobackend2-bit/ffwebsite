Options -MultiViews
RewriteEngine On

# Serve existing files and directories directly (JS, CSS, images, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# For dynamic routes (/products/id, /orders/id), fall back to index.html
# The Next.js client router handles the rest
RewriteRule ^ /index.html [QSA,L]

# ─── CACHE CONTROL (Crucial for Hostinger SPA Deployments) ───
<IfModule mod_headers.c>
    # 1. Never cache HTML files (Ensures users always get the newest CSS chunk URLs)
    <FilesMatch "\.(html|htm|txt|json)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # 2. Aggressively cache static assets (CSS, JS, Fonts, Images are hashed by Next.js)
    <FilesMatch "\.(css|js|woff|woff2|ttf|otf|eot|png|jpe?g|gif|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
